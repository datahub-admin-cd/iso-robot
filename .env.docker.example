# Copy to .env before: docker compose up --build
# Azure keys are optional if USE_LLM_FALLBACK=true (default).

# API_PORT=8000
# DOCS_PORT=3005
# LOG_LEVEL=INFO
# RUN_SEED_DEMO=true

# DATABASE_PATH=/app/backend/data/db.sqlite
# Per-org uploads live beside the DB: {dirname(DATABASE_PATH)}/org_documents/{org_slug}/...
# On a VM without Docker, e.g. DATABASE_PATH=/home/ubuntu/iso-robot/backend/data/db.sqlite
# DOCUMENTS_DIR=/app/all-docs

# JWT_SECRET_KEY=change-me-in-production

# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
# AZURE_DOCUMENT_INTELLIGENCE_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Azure OpenAI embedding deployment, e.g. text-embedding-3-small (1536-dim).
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
# AZURE_OPENAI_EMBEDDING_DIM=1536

# Milvus vector DB
# In Docker Compose the API reaches Milvus at the service hostname below.
# MILVUS_URI=http://milvus-standalone:19530
# MILVUS_TOKEN=
# MILVUS_DB_NAME=default
# MILVUS_COLLECTION=iso_robot_knowledge

# Chatbot retrieval (optional tuning)
# CHATBOT_TOP_K=8
# CHATBOT_MAX_CONTEXT_CHARS=12000
